# Ignore folders which are generated during runtime
/outputs/
*.pyc

# Choir Studio build artifacts
choir_studio/node_modules/
choir_studio/dist/
choir_studio/src-tauri/target/
choir_studio/src-tauri/gen/
choir_studio/src-tauri/resources/runtime_template/*
!choir_studio/src-tauri/resources/runtime_template/.gitkeep
!choir_studio/src-tauri/resources/runtime_template/runtime-manifest.placeholder
choir_studio/*.tsbuildinfo
choir_studio/vite.config.js
choir_studio/vite.config.d.ts

# Extra folders
zips/*
klattclassic/*
dectalk/*
external/*

# Ignore all songs except for the included example tracks

songs/*

!songs/CarolOfTheBells_Short*
!songs/AuldLangSyne*
!songs/DaisyBell*
!songs/CantHelpFalling*
!songs/OctaveBoostReference*
!songs/HeadSizePitchReference*

# Generated artifacts remain co-located with each song but are never source.
songs/*/outputs/
!songs/HeadSizePitchReference/outputs/
songs/HeadSizePitchReference/outputs/*
!songs/HeadSizePitchReference/outputs/_finished/
!songs/HeadSizePitchReference/outputs/_finished/*.wav
!songs/HeadSizePitchReference/outputs/_tracks/
!songs/HeadSizePitchReference/outputs/_tracks/*.wav
!songs/OctaveBoostReference/outputs/
songs/OctaveBoostReference/outputs/*
!songs/OctaveBoostReference/outputs/_finished/
!songs/OctaveBoostReference/outputs/_finished/*.wav
!songs/OctaveBoostReference/outputs/_tracks/
!songs/OctaveBoostReference/outputs/_tracks/*.wav
songs/*/inputs/lyrics/*.original.txt
songs/*/inputs/lyrics/*.before-alignment.txt
songs/*/inputs/*.bak
songs/*/inputs/* - Backup.mmpz
songs/*/inputs/*_split_summary.txt
