{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DECTALK Choir GUI",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/choir_gui.py",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "DECTALK Choir Studio (Tauri)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm.cmd exec tauri dev",
      "cwd": "${workspaceFolder}/choir_studio"
    }
  ]
}
