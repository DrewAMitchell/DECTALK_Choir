{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DECTALK Choir Studio",
  "version": "0.2.0",
  "identifier": "org.dectalkchoir.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:release",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DECTALK Choir Studio",
        "width": 1100,
        "height": 500,
        "minWidth": 1040,
        "minHeight": 420,
        "decorations": false,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "DECTALK Choir Studio",
        "url": "splashscreen.html",
        "width": 420,
        "height": 260,
        "center": true,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": ["resources/runtime_template/**/*"]
  }
}
