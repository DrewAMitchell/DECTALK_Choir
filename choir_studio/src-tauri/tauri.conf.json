{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DECTALK Choir Studio",
  "version": "0.1.0",
  "identifier": "org.dectalkchoir.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:release",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DECTALK Choir Studio",
        "width": 1100,
        "height": 500,
        "minWidth": 1040,
        "minHeight": 420
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": ["resources/runtime_template/**/*"]
  }
}
